PORT=3000
# Production: set to your Vercel URL, e.g. https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_secure_value
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
# Production: Render user-service URL
USER_SERVICE_URL=http://localhost:4001
# Production: Render photo-service URL
PHOTO_SERVICE_URL=http://localhost:4002
INTERNAL_JWT_SECRET=replace_with_shared_internal_jwt_secret
